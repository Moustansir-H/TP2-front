<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.auth.controller.AuthController"
            prefWidth="760.0" prefHeight="560.0"
            stylesheets="@auth-style.css">

    <top>
        <VBox spacing="6.0" styleClass="card">
            <Label text="Client Auth TP3 (FXML)" styleClass="title"/>
            <GridPane hgap="10.0" vgap="8.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="130.0"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Backend URL:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="serverUrlField" prefWidth="450.0" promptText="http://localhost:8080"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Register path:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="registerPathField" promptText="/api/auth/register"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Login path:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="loginPathField" promptText="/api/auth/login"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Mode login:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <CheckBox fx:id="ssoModeCheckBox" text="SSO TP3 (email + nonce + timestamp + hmac)"
                          selected="true" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Inscription">
                    <content>
                        <VBox spacing="12.0" styleClass="card">
                            <Label text="Creer un compte" styleClass="subtitle"/>

                            <GridPane hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="170.0"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="Email" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="registerEmailField" promptText="nom@domaine.com"
                                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Mot de passe" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <PasswordField fx:id="registerPasswordField" promptText="12+ car., maj, min, chiffre, special"
                                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Confirmer mot de passe" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <PasswordField fx:id="registerPasswordConfirmField" promptText="Retaper le mot de passe"
                                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            </GridPane>

                            <VBox spacing="6.0">
                                <Label text="Force du mot de passe"/>
                                <ProgressBar fx:id="strengthBar" prefWidth="500.0" progress="0.0"/>
                                <Label fx:id="strengthLabel" text="Rouge - non conforme"/>
                            </VBox>

                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Button fx:id="registerButton" text="S'inscrire" onAction="#onRegister"/>
                                <Label fx:id="registerStatusLabel" wrapText="true"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Login">
                    <content>
                        <VBox spacing="12.0" styleClass="card">
                            <Label text="Connexion" styleClass="subtitle"/>

                            <GridPane hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="170.0"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="Email" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="loginEmailField" promptText="nom@domaine.com"
                                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Mot de passe" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <PasswordField fx:id="loginPasswordField" promptText="Mot de passe"
                                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            </GridPane>

                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Button fx:id="loginButton" text="Se connecter" onAction="#onLogin"/>
                                <Label fx:id="loginStatusLabel" wrapText="true"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>

    <padding>
        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
    </padding>
</BorderPane>

